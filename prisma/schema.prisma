generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  BICEPS
  TRICEPS
  LEGS
  GLUTES
  CORE
  FOREARMS
  CALVES
  FULL_BODY
  CARDIO
  OTHER
}

enum Equipment {
  BARBELL
  DUMBBELL
  MACHINE
  CABLE
  BODYWEIGHT
  KETTLEBELL
  BAND
  OTHER
}

enum WeightUnit {
  KG
  LB
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum AppLocale {
  EN
  DE
}

// ─── User ───────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  exercises       Exercise[]
  workouts        Workout[]
  workoutPlans    WorkoutPlan[]
  bodyWeights      BodyWeight[]
  bodyMeasurements BodyMeasurement[]
  healthSnapshots  HealthSnapshot[]
  appleWorkouts    AppleWorkout[]
  personalRecords  PersonalRecord[]
  settings        UserSettings?
  apiTokens       ApiToken[]

  @@map("users")
}

model ApiToken {
  id          String    @id @default(uuid())
  userId      String
  name        String?
  tokenHash   String    @unique
  tokenPrefix String
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_tokens")
}

model UserSettings {
  id               String     @id @default(uuid())
  userId           String     @unique
  weightUnit       WeightUnit @default(KG)
  theme            Theme      @default(SYSTEM)
  restTimerDefault Int        @default(90)
  locale           AppLocale  @default(EN)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ─── Exercise ───────────────────────────────────────────

model Exercise {
  id          String      @id @default(uuid())
  userId      String?
  name        String
  muscleGroup MuscleGroup
  equipment   Equipment   @default(BODYWEIGHT)
  notes       String?
  isCustom    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  user             User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutExercises      WorkoutExercise[]
  planSessionExercises  PlanSessionExercise[]
  personalRecords       PersonalRecord[]

  @@index([userId])
  @@index([muscleGroup])
  @@map("exercises")
}

// ─── Workout plans (reusable templates) ─────────────────

model WorkoutPlan {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions PlanSession[]

  @@index([userId])
  @@map("workout_plans")
}

model PlanSession {
  id          String   @id @default(uuid())
  planId      String
  name        String
  order       Int
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plan       WorkoutPlan           @relation(fields: [planId], references: [id], onDelete: Cascade)
  exercises  PlanSessionExercise[]
  workouts   Workout[]

  @@index([planId])
  @@map("plan_sessions")
}

model PlanSessionExercise {
  id            String @id @default(uuid())
  planSessionId String
  exerciseId    String
  order         Int
  targetSets    Int    @default(3)

  planSession PlanSession @relation(fields: [planSessionId], references: [id], onDelete: Cascade)
  exercise    Exercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([planSessionId])
  @@map("plan_session_exercises")
}

// ─── Workout ────────────────────────────────────────────

model Workout {
  id              String    @id @default(uuid())
  userId          String
  name            String?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  notes           String?
  durationSeconds Int?
  planSessionId   String?

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  planSession      PlanSession?      @relation(fields: [planSessionId], references: [id], onDelete: SetNull)
  workoutExercises WorkoutExercise[]

  @@index([userId, startedAt])
  @@index([userId, completedAt])
  @@index([planSessionId])
  @@map("workouts")
}

model WorkoutExercise {
  id          String  @id @default(uuid())
  workoutId   String
  exerciseId  String
  order       Int
  notes       String?
  isCompleted Boolean @default(false)

  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])
  sets     Set[]

  @@index([workoutId])
  @@map("workout_exercises")
}

model Set {
  id                String    @id @default(uuid())
  workoutExerciseId String
  setNumber         Int
  reps              Int?
  weight            Float?
  durationSeconds   Int?
  rpe               Float?
  isWarmup          Boolean   @default(false)
  isCompleted       Boolean   @default(false)
  completedAt       DateTime?

  workoutExercise WorkoutExercise  @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  personalRecord  PersonalRecord?

  @@index([workoutExerciseId])
  @@map("sets")
}

// ─── Tracking ───────────────────────────────────────────

model BodyWeight {
  id        String   @id @default(uuid())
  userId    String
  weight    Float
  date      DateTime @db.Date
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("body_weights")
}

model BodyMeasurement {
  id         String   @id @default(uuid())
  userId     String
  date       DateTime @db.Date
  // All values in cm (or inches — same unit preference as weightUnit)
  neck       Float?
  chest      Float?
  leftArm    Float?
  rightArm   Float?
  waist      Float?
  hips       Float?
  leftThigh  Float?
  rightThigh Float?
  notes      String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("body_measurements")
}

model HealthSnapshot {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime @db.Date

  // Sleep
  sleepDuration    Float? // hours
  sleepBedtime     String? // "HH:MM"
  sleepWakeTime    String? // "HH:MM"
  sleepDeepMinutes Int?
  sleepRemMinutes  Int?
  sleepQuality     Int? // 0–100

  // Heart Rate
  restingHeartRate Int? // bpm
  heartRateAvg     Int? // bpm
  hrv              Float? // ms (RMSSD)

  // Nightly vitals — early illness / systemic-stress signals
  respiratoryRate  Float? // breaths/min (nightly average)
  wristTemperature Float? // °C (nightly wrist temp; deviation computed vs personal baseline)

  // Activity
  steps           Int?
  activeCalories  Float? // kcal
  exerciseMinutes Int?
  standHours      Int?

  // Cardio fitness
  vo2Max Float? // ml/kg/min

  // Nutrition — energy expenditure
  calories Float? // kcal basal energy burned (Apple Health basal)

  // Nutrition — intake (food consumed)
  dietaryCalories Float? // kcal consumed
  protein         Float? // g
  carbs           Float? // g
  fat             Float? // g
  fiber           Float? // g
  sugar           Float? // g
  sodium          Float? // mg
  caffeine        Float? // mg
  water           Float? // ml

  // Micronutrients
  vitaminD  Float? // mcg
  vitaminC  Float? // mg
  calcium   Float? // mg
  iron      Float? // mg
  potassium Float? // mg
  magnesium Float? // mg

  // Mindfulness
  mindfulMinutes Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("health_snapshots")
}

// Cardio / workout sessions imported from Apple Health via HAE.
// Distinct from the user-logged `Workout` model (strength training).
// Stores one row per Apple-Health-recorded session.
model AppleWorkout {
  id         String   @id @default(uuid())
  userId     String
  externalId String   // HAE/Apple Health UUID — used to dedupe re-syncs

  type       String   // "Running", "Cycling", "Swimming", "Strength Training", "HIIT", ...
  startedAt  DateTime
  endedAt    DateTime
  durationSec Int

  // Optional metrics — many depend on workout type & device
  distanceMeters Float?
  activeCalories Float? // kcal
  totalCalories  Float? // kcal (includes basal)
  avgHeartRate   Int?   // bpm
  maxHeartRate   Int?   // bpm
  elevationGainM Float?
  source         String? // "Apple Watch Series 10", "iPhone", ...

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externalId])
  @@index([userId, startedAt])
  @@map("apple_workouts")
}

model PersonalRecord {
  id           String   @id @default(uuid())
  userId       String
  exerciseId   String
  weight       Float
  reps         Int
  estimated1RM Float?
  achievedAt   DateTime @default(now())
  setId        String   @unique

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])
  set      Set      @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@index([userId, exerciseId])
  @@map("personal_records")
}
