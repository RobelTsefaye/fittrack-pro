# ── Database ─────────────────────────────────────────────
# For local dev (Prisma local server):
#   DATABASE_URL="prisma+postgres://localhost:51213/?api_key=..."
#   DIRECT_DATABASE_URL="postgres://postgres:postgres@localhost:51214/template1"
#
# For production (Neon / Supabase / any cloud Postgres):
#   DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"
DATABASE_URL=""

# Direct connection (bypasses Prisma proxy, used for migrations + seed)
# In production with Neon, use the same URL as DATABASE_URL
DIRECT_DATABASE_URL=""

# ── Auth ─────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""

# Required by NextAuth v5 — set to your production domain
# e.g. https://fittrack.vercel.app
AUTH_URL=""

# ── App ──────────────────────────────────────────────────
# Same URL you open in the browser (Mac + phone). Shown in Settings for
# “use on every device”. Production: https://your-app.vercel.app
# Local LAN phone testing: http://192.168.x.x:3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"
